@echo off
chcp 65001 > nul
echo ============================================
echo    个人博客系统 - 一键停止脚本
echo ============================================
echo.

:: 停止前端
echo 正在停止前端服务...
taskkill /f /im node.exe > nul 2>&1
echo 前端已停止

:: 停止后端
echo 正在停止后端服务...
taskkill /f /im java.exe > nul 2>&1
echo 后端已停止

echo.
echo ============================================
echo    所有服务已停止
echo ============================================
pause
